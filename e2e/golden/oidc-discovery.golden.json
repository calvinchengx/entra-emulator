{
  "_comment": "Golden reference for the OIDC discovery document. Provenance in README.md.",
  "source": "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration",
  "captured": "2026-07-13",
  "required_fields": [
    "issuer",
    "authorization_endpoint",
    "token_endpoint",
    "jwks_uri",
    "userinfo_endpoint",
    "device_authorization_endpoint",
    "end_session_endpoint",
    "response_types_supported",
    "response_modes_supported",
    "subject_types_supported",
    "scopes_supported",
    "id_token_signing_alg_values_supported",
    "token_endpoint_auth_methods_supported",
    "claims_supported"
  ],
  "protocol_values": {
    "subject_types_supported_equals": ["pairwise"],
    "id_token_signing_alg_values_must_include": ["RS256"],
    "response_types_supported_subset_of": [
      "code",
      "id_token",
      "code id_token",
      "id_token token"
    ],
    "response_modes_supported_subset_of": ["query", "fragment", "form_post"],
    "scopes_supported_must_include": [
      "openid",
      "profile",
      "email",
      "offline_access"
    ],
    "token_endpoint_auth_methods_subset_of": [
      "client_secret_post",
      "client_secret_basic",
      "private_key_jwt",
      "self_signed_tls_client_auth"
    ],
    "claims_supported_must_include": [
      "sub",
      "iss",
      "aud",
      "exp",
      "iat",
      "tid",
      "name",
      "preferred_username",
      "email",
      "nonce",
      "ver"
    ]
  },
  "entra_only_fields_out_of_scope": [
    "request_uri_parameter_supported",
    "http_logout_supported",
    "frontchannel_logout_supported",
    "kerberos_endpoint",
    "mtls_endpoint_aliases",
    "tls_client_certificate_bound_access_tokens",
    "tenant_region_scope",
    "cloud_instance_name",
    "cloud_graph_host_name",
    "msgraph_host",
    "rbac_url"
  ]
}
